{
  "$schema": "https://raw.githubusercontent.com/nicabar/tauri/refs/heads/v2/packages/tauri/schema/capability.json",
  "identifier": "default",
  "description": "Default capability for main and overlay windows",
  "windows": ["main", "overlay"],
  "permissions": [
    "core:default",
    "core:window:allow-create",
    "core:window:allow-close",
    "core:window:allow-destroy",
    "core:window:allow-set-ignore-cursor-events",
    "core:window:allow-set-always-on-top",
    "core:window:allow-set-size",
    "core:window:allow-set-position",
    "core:window:allow-set-focus",
    "core:window:allow-set-decorations",
    "core:window:allow-start-dragging",
    "core:window:allow-set-resizable",
    "core:window:allow-show",
    "core:window:allow-hide",
    "core:window:allow-minimize",
    "core:window:allow-unminimize",
    "core:window:allow-outer-size",
    "core:window:allow-outer-position",
    "core:window:allow-current-monitor",
    "core:window:allow-available-monitors",
    "core:webview:allow-create-webview-window",
    "core:event:default",
    "shell:allow-execute",
    "shell:allow-open",
    "store:default",
    "fs:default",
    {
      "identifier": "fs:allow-read-file",
      "allow": [
        { "path": "$TEMP/prospertogether/**" },
        { "path": "$APPDATA/recordings/**" }
      ]
    },
    {
      "identifier": "fs:allow-stat",
      "allow": [
        { "path": "$TEMP/prospertogether/**" },
        { "path": "$APPDATA/recordings/**" }
      ]
    },
    {
      "identifier": "fs:allow-remove",
      "allow": [
        { "path": "$TEMP/prospertogether/**" },
        { "path": "$APPDATA/recordings/**" }
      ]
    },
    "notification:default",
    "updater:default",
    "deep-link:default",
    "autostart:default",
    "global-shortcut:default"
  ]
}
